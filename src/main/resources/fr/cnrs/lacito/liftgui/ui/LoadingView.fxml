<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           styleClass="loading-root"
           prefWidth="600" prefHeight="400">
  <VBox alignment="CENTER" spacing="20">
    <VBox alignment="CENTER" spacing="4">
      <Label text="Application d'édition de" styleClass="loading-title"/>
      <Label text="dictionnaires multilingues" styleClass="loading-title"/>
    </VBox>
    <ProgressBar fx:id="progressBar" styleClass="loading-progress" prefWidth="380" prefHeight="6" progress="0"/>
  </VBox>
</StackPane>
