<relation type="Comparer" ref="fɛr lɔ ʃmi_b762b47f-c448-4331-ba77-54057eeb9e55"/>
<sense id="4326ea3c-c386-41e6-8ebb-5fad133c4235">
<grammatical-info value="Nom">
<trait name="Nom-infl-class" value="Féminin"/></grammatical-info>
<gloss lang="fr"><text>lisière_de_champ</text></gloss>
<definition>
<form lang="fr"><text>bande de terre en lisière de la planche de labour ensemencée et moissonné à part.</text></form>
</definition>
<trait name ="semantic-domain-ddp4" value="6.2 Agriculture"/>
<note type="anthropology">
<form lang="fr"><text>Cet espace est utilisé pour tourner les attelages lors du labour et de l'ensemencement au semoir. il est présent surtout sur les côtés perpendiculaires aux sillons, et typiquement pour un champ de blé ou de céréale. Il est ensemencé (en longueur) après le champ principal et moissonné avant le champ principal.</text></form>
</note>
<trait  name="usage-type" value="realia vieilli"/>
</sense>
</entry>
