<entry dateCreated="2021-07-23T08:55:23Z" dateModified="2021-07-23T09:01:29Z" id="ãtabaj_cf8e21dc-590f-4931-b7e8-8b8a2b2d38a6" guid="cf8e21dc-590f-4931-b7e8-8b8a2b2d38a6">
<lexical-unit>
<form lang="oc-FR-fonipa"><text>ãtabaj</text></form>
</lexical-unit>
<trait  name="morph-type" value="stem"/>
<sense id="3de1ab71-4595-4c16-855b-4fd930195a72" order="0">
<grammatical-info value="Verbe">
</grammatical-info>
<gloss lang="fr"><text>entraver</text></gloss>
<definition>
<form lang="fr"><text>limiter les mouvements d'une vache en suspendant une pièce de bois  suffisamment lourde sous son poitrail.</text></form>
</definition>
<relation type="Causatif" ref="d180f639-5081-4a0f-be2c-d9be0bad04d7"/>
</sense>
<sense id="48f7adfc-1b75-4a88-8b1f-21aa7c504651" order="1">
<grammatical-info value="Verbe">
</grammatical-info>
<definition>
<form lang="fr"><text>Se prendre les pieds dans un vêtement long</text></form>
</definition>
</sense>
</entry>
