<entry dateCreated="2016-04-09T11:56:07Z" dateModified="2026-03-02T14:59:05Z" id="palisu_b83f363e-65f2-447e-8be4-8c138c1ac8f4" guid="b83f363e-65f2-447e-8be4-8c138c1ac8f4">
<lexical-unit>
<form lang="oc-FR-fonipa"><text>palisu</text></form>
</lexical-unit>
<trait  name="morph-type" value="stem"/>
<citation>
<form lang="oc-FR-fonipa"><text>palisu</text></form>
</citation>
<note>
<form lang="fr"><text>QuestionnaireLexical1 ,<span lang="oc-FR-fonipa">CheckedDanielle2016</span></text></form>
</note>
<etymology type="borrowed" source="">
<form lang="fr"><text>lt. palea ‘paille’</text></form>
<field type="comment">
<form lang="fr"><text>Un dérivé de palea ‘ruche’ n’est mentionné que dans hauv. (en Auvergne) dans FEW : 7:493b (bas) : paglia ; puis dans Tarn, Cévenne : pailhasso, paɬάso (494 a) ; nombreux autres formes plus généralement ‘corbeille’ + ‘couverture de paille sur ruche’.</text></form>
</field>
<field type="bibliography">
<form lang="fr"><text>FEW 7:493b</text></form>
</field>
</etymology>
<sense id="91e2f099-7336-4e9e-bb47-d50f81cbafd8" order="0">
<grammatical-info value="Nom">
</grammatical-info>
<gloss lang="fr"><text>type_de_vannerie</text></gloss>
<definition>
<form lang="fr"><text>Technique de vannerie utilisant de la paille de seigle et de l'écorce de ronce</text></form>
</definition>
<trait name ="semantic-domain-ddp4" value="6.6.4 Artisanat"/>
</sense>
<sense id="773ad594-ba95-43ab-86e0-fc140842c739" order="1">
<grammatical-info value="Nom">
</grammatical-info>
<gloss lang="fr"><text>panière</text></gloss>
<definition>
<form lang="fr"><text>panière</text></form>
</definition>
<trait name ="semantic-domain-ddp4" value="6.2 Agriculture"/>
<trait name ="semantic-domain-ddp4" value="5.1 Équipement de la maison"/>
<note type="anthropology">
<form lang="fr"><text>Corbeille réalisée en paille de sègle et écorce de ronce, servant à recevoir la pâte à pain pendant qu'elle lève (panière), puis, usagée, utilisée comme pondoir dans le poulailler.</text></form>
</note>
<trait  name="sense-type" value="par métonymie"/>
</sense>
<sense id="217bef0c-675a-4d21-8e20-8723ba495942" order="2">
<grammatical-info value="Nom">
</grammatical-info>
<gloss lang="fr"><text>ruche</text></gloss>
<definition>
<form lang="fr"><text>Ruche en paille tressé, avec de l'écorce de ronce,</text></form>
</definition>
<trait name ="semantic-domain-ddp4" value="6.2 Agriculture"/>
<note type="anthropology">
<form lang="fr"><text>posée sur des caisses en bois</text></form>
</note>
<trait  name="sense-type" value="par métonymie"/>
<relation type="Synonyme" ref="4db0ca79-3375-4c15-8f23-2c9140392e53"/>
</sense>
<sense id="0979b9a2-4964-464d-a48c-c3df62ef2446" order="3">
<grammatical-info value="Nom">
</grammatical-info>
<gloss lang="fr"><text>Corbeille</text></gloss>
<definition>
<form lang="fr"><text>Corbeille en paille tressée pour lever la pate à pain</text></form>
</definition>
</sense>
</entry>
