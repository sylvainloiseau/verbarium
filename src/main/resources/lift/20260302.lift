<grammatical-info value="Préposition">
</grammatical-info>
<gloss lang="fr"><text>avec_la_famille_X</text></gloss>
<definition>
<form lang="fr"><text>avec (une famille, les membres d'une maison)</text></form>
</definition>
<example source="Scene03_071">
<form lang="oc-FR-fonipa"><text>õ kozɛv pa ʃe niko e ʃe kõb.</text></form>
<translation type="Traduction libre">
<form lang="fr"><text>On ne parlait pas avec les Nicaud et les Combe</text></form>
</translation>
<note type="reference">
<form lang="en"><text>Scene03_071</text></form>
</note>
</example>
<note type="semantics">
<form lang="fr"><text><span lang="oc-FR-fonipa">"a mɛzu</span>" : le batiment et la famille; "<span lang="oc-FR-fonipa">ʃe</span>" : avec la famille (Scene03_071, com.)</text></form>
</note>
<relation type="Quasi synonyme" ref="7deb32a4-47a0-4bf4-861d-5e07eafa000a"/>
<trait name="Particularism" value="Semantic"/>
</sense>
</entry>
